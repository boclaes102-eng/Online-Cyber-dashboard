# ── Clerk Auth (required) ──────────────────────────────────────────────────────
# Create a free account at clerk.com, create an app (Email + Password),
# then copy your keys from the API Keys page.
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_...
CLERK_SECRET_KEY=sk_test_...

# Clerk routing (keep these as-is)
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/

# ── Threat Intelligence Platform (Asset Monitor) ───────────────────────────
# Your self-hosted backend — deployed on Railway
THREAT_INTEL_API_URL=https://threat-intel-platform-production-eb1b.up.railway.app
THREAT_INTEL_API_KEY=

# ── Optional API keys — tools work without these but gain extra data ────────

# AbuseIPDB — free tier: 1,000 checks/day (IP tool + IOC lookup)
# https://www.abuseipdb.com/account/api
ABUSEIPDB_API_KEY=

# VirusTotal — free tier: 4 requests/minute (Hash Scanner + URL Scanner + IOC lookup)
# https://www.virustotal.com/gui/my-apikey
VT_API_KEY=

# NVD (NIST) — free, raises CVE rate limit from 5/30s to 50/30s
# https://nvd.nist.gov/developers/request-an-api-key
NVD_API_KEY=

# Shodan — free account at shodan.io → Dashboard → API Key
SHODAN_API_KEY=

# AlienVault OTX — free account, unlimited lookups
# https://otx.alienvault.com/api
OTX_API_KEY=

# PhishTank — free account
# https://phishtank.org/api_info.php
PHISHTANK_API_KEY=
