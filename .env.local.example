# ── Optional API keys — tools work without these but gain extra data ────────
# Copy this file to .env.local and fill in the keys you want.

# ── Existing keys ────────────────────────────────────────────────────────────

# AbuseIPDB — free tier: 1,000 checks/day (IP tool + IOC lookup)
# https://www.abuseipdb.com/account/api
ABUSEIPDB_API_KEY=

# VirusTotal — free tier: 4 requests/minute (Hash Scanner + URL Scanner + IOC lookup)
# https://www.virustotal.com/gui/my-apikey
VT_API_KEY=

# NVD (NIST) — free, raises CVE rate limit from 5/30s to 50/30s
# https://nvd.nist.gov/developers/request-an-api-key
NVD_API_KEY=

# ── New keys ─────────────────────────────────────────────────────────────────

# Shodan — free account at shodan.io → Dashboard → API Key
# Used by: Port Scanner (falls back to live TCP scan without this)
# https://account.shodan.io
SHODAN_API_KEY=

# AlienVault OTX — free account, unlimited lookups
# Used by: IOC Lookup (IP, domain, hash, URL threat intel)
# https://otx.alienvault.com/api
OTX_API_KEY=
